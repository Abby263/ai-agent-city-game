# Memory storage
# short_term works without Neon/Supabase. In the browser game, short-term
# gameplay memory is stored in localStorage so Vercel serverless cold starts
# do not reset the player's active task/conversation loop.
# Set MEMORY_STORAGE=postgres only when you want durable cloud memory.
MEMORY_STORAGE=short_term
DATABASE_FALLBACK_URL=sqlite+pysqlite:////tmp/agentcity-short-term.db

# Optional durable cloud database
# SQLAlchemy accepts postgres://, postgresql://, or postgresql+psycopg:// here.
DATABASE_URL=
SUPABASE_DATABASE_URL=
NEON_DATABASE_URL=
ALLOW_EPHEMERAL_DB_FALLBACK=true

LLM_MODE=real
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MAX_LLM_CALLS_PER_TICK=2
MAX_CONVERSATIONS_PER_TICK=1
LLM_COGNITION_INTERVAL_TICKS=4
TICK_MINUTES=15
ACTIVE_CITIZEN_IDS=profile
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/city
# Default is browser. Set to server only when using durable Postgres state.
NEXT_PUBLIC_MEMORY_MODE=browser
